# Copia este fichero a .env y rellena los valores
# cp .env.example .env

# iron-session: mínimo 32 caracteres, usa un valor aleatorio en producción
SESSION_SECRET="change-me-in-production-min-32-chars!!"

# Base de datos SQLite local
DATABASE_URL="file:./dev.db"

# hCaptcha — dejar en blanco en dev para saltarse la verificación
HCAPTCHA_SECRET_KEY=""
NEXT_PUBLIC_HCAPTCHA_SITE_KEY=""

# IDs de usuario admin separados por comas (también se puede usar la tabla AdminUser)
ADMIN_USERIDS=""

# URL del backend del servidor de juego
NEXT_PUBLIC_API_URL="https://yinx-ragnarok.duckdns.org"

# URL del endpoint de previsualización de sprites (xro-server, opcional)
# NEXT_PUBLIC_CHAR_PREVIEW_URL="https://yinx-ragnarok.duckdns.org"
